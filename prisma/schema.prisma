model TaskBlocker {
  id             String          @id @default(cuid())
  companyId      String
  projectId      String
  taskId         String
  userId         String
  title          String
  description    String
  status         BlockerStatus   @default(OPEN)
  severity       BlockerSeverity @default(MEDIUM)
  followUpAction String?
  followUpOwnerId String?
  followUpDate   DateTime?
  followUpStatus BlockerFollowUpStatus?
  lastFollowUpAt DateTime?
  outcomeStatus  BlockerOutcomeStatus @default(UNVERIFIED)
  outcomeSummary String?
  verifiedByUserId String?
  verifiedAt     DateTime?
  reopenedAt     DateTime?
  reopenReason   String?
  resolutionNote String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  resolvedAt     DateTime?
  company        Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  project        Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  task           Task            @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  followUpOwner  User?           @relation("BlockerFollowUpOwner", fields: [followUpOwnerId], references: [id], onDelete: SetNull)
  verifiedBy     User?           @relation("BlockerVerifiedBy", fields: [verifiedByUserId], references: [id], onDelete: SetNull)
  preventiveActions PreventiveAction[] @relation("PreventiveActionSourceBlocker")

  @@index([companyId, status, severity])
  @@index([projectId, status, createdAt])
  @@index([taskId, status, createdAt])
  @@index([userId, createdAt])
  @@index([followUpOwnerId, followUpDate])
  @@index([verifiedByUserId, verifiedAt])
}

model PreventiveAction {
  id              String                 @id @default(cuid())
  companyId       String
  projectId       String?
  relatedTaskId   String?
  sourceBlockerId String?
  ownerId         String?
  title           String
  description     String
  status          PreventiveActionStatus @default(PROPOSED)
  dueDate         DateTime?
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt
  company         Company                @relation(fields: [companyId], references: [id], onDelete: Cascade)
  project         Project?               @relation(fields: [projectId], references: [id], onDelete: SetNull)
  relatedTask     Task?                  @relation(fields: [relatedTaskId], references: [id], onDelete: SetNull)
  sourceBlocker   TaskBlocker?           @relation("PreventiveActionSourceBlocker", fields: [sourceBlockerId], references: [id], onDelete: SetNull)
  owner           User?                  @relation("PreventiveActionOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  executionImprovements ExecutionImprovement[]

  @@index([companyId, status, dueDate])
  @@index([projectId, status])
  @@index([relatedTaskId, status])
  @@index([sourceBlockerId])
  @@index([ownerId, dueDate])
}

model ChecklistItem {
