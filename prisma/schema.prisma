  linkedProjectTemplateId String?
  createdAt               DateTime            @default(now())
  updatedAt               DateTime            @updatedAt
  company                 Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  linkedProjectTemplate   WorkTemplate?       @relation(fields: [linkedProjectTemplateId], references: [id], onDelete: SetNull)

  @@index([companyId, status])
  @@index([linkedProjectTemplateId])
}

model ExecutionImprovement {
  id                       String                        @id @default(cuid())
  companyId                String
  projectId                String?
  relatedTaskId            String?
  sourcePreventiveActionId String?
  title                    String
  description              String
  targetType               ExecutionImprovementTargetType
  status                   ExecutionImprovementStatus    @default(PROPOSED)
  appliesToFutureTasks     Boolean                       @default(true)
  createdAt                DateTime                      @default(now())
  updatedAt                DateTime                      @updatedAt
  company                  Company                       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  project                  Project?                      @relation(fields: [projectId], references: [id], onDelete: SetNull)
