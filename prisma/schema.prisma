  sourcePreventiveAction   PreventiveAction?             @relation(fields: [sourcePreventiveActionId], references: [id], onDelete: SetNull)
  checklistItems           ChecklistItem[]
  taskApplications         TaskAppliedImprovement[]
  templateChecklistItems   TemplateChecklistItem[]
  templateLinks            TemplateExecutionImprovement[]

  @@index([companyId, status, targetType])
  @@index([projectId, status])
  @@index([relatedTaskId, status])
  @@index([sourcePreventiveActionId])
}

model TaskAppliedImprovement {
  id                     String               @id @default(cuid())
  companyId              String
  taskId                 String
  executionImprovementId String
  createdAt              DateTime             @default(now())
  company                Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  task                   Task                 @relation(fields: [taskId], references: [id], onDelete: Cascade)
  executionImprovement   ExecutionImprovement @relation(fields: [executionImprovementId], references: [id], onDelete: Cascade)

  @@unique([taskId, executionImprovementId])
  @@index([companyId, createdAt])
  @@index([executionImprovementId])
}
